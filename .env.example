# Kopiere diese Datei nach .env und trage deinen API-Key ein,
# wenn du das optionale LLM-Segment-Scoring nutzen willst.
# Ohne .env / ohne API_KEY laeuft das Tool trotzdem vollstaendig,
# einfach ohne KI-Bewertung der Transkript-Segmente (Fallback,
# kein Fehler).

# Welcher Anbieter genutzt werden soll: "groq" oder "openrouter"
API_PROVIDER=groq

# Dein API-Key vom jeweiligen Anbieter (Free-Tier ausreichend)
API_KEY=

# Optional: Modellname ueberschreiben (sonst wird der Default aus
# config.yaml verwendet)
API_MODEL=
